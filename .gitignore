# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  ConstruxionARQ — .gitignore
#  Next.js 14 · TypeScript · Tailwind · SiteGround FTP
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━


# ── Dependencies ──────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz


# ── Build outputs ─────────────────────────────────────
# (estos los genera el build — no van al repo)
.next/
out/
dist/
build/
*.tsbuildinfo


# ── FTP Deploy (GitHub Actions) ───────────────────────
# Este archivo lo genera SamKirkland/FTP-Deploy-Action
# para trackear qué archivos ya se subieron.
# No debe ir al repo.
.ftp-deploy-sync-state.json


# ── Environment variables & Local Backups ─────────────
# Nunca subas credenciales ni contraseñas reales al repo
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# Respaldos locales con contraseñas en texto plano (¡Muy importante!)
DEPLOY_INFO.md
README_DEPLOY.md


# ── Videos grandes (subir manualmente a SiteGround) ───
# GitHub bloquea archivos mayores a 50MB
public/videos/*.mp4
public/videos/*.mov
public/videos/*.avi
public/videos/*.webm


# ── Logs ──────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*


# ── OS / Editor ───────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?


# ── IDE ───────────────────────────────────────────────
.vscode/
.idea/
*.iml


# ── Testing / Coverage ────────────────────────────────
coverage/
.nyc_output/


# ── Misc ──────────────────────────────────────────────
.vercel
.netlify
.cache/
*.tgz

# ── Scripts temporales de scraping ────────────────────
scrape-images.js
scrape-datos.js
show-structure.ps1