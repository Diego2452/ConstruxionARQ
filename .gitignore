# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  ConstruxionARQ — .gitignore
#  Next.js 14 · TypeScript · Tailwind · SiteGround FTP
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━


# ── Dependencies ──────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz


# ── Build outputs ─────────────────────────────────────
# (estos los genera el build — no van al repo)
.next/
out/
dist/
build/
*.tsbuildinfo


# ── FTP Deploy (GitHub Actions) ───────────────────────
# Este archivo lo genera SamKirkland/FTP-Deploy-Action
# para trackear qué archivos ya se subieron.
# No debe ir al repo.
.ftp-deploy-sync-state.json


# ── Environment variables ─────────────────────────────
# Nunca subas credenciales al repo
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local


# ── Logs ──────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*


# ── OS / Editor ───────────────────────────────────────
.DS_Store           # macOS
Thumbs.db           # Windows
Desktop.ini
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?               # Vim swap files


# ── IDE ───────────────────────────────────────────────
.vscode/
.idea/
*.iml


# ── Testing / Coverage ────────────────────────────────
coverage/
.nyc_output/


# ── Misc ──────────────────────────────────────────────
.vercel             # Por si algún día se prueba Vercel
.netlify
.cache/
*.tgz